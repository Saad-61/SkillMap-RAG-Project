# Hugging Face access token to avoid anonymous rate limits.
# Create backend/.env from this file and put your real token.
HF_TOKEN=your_hf_token_here

# Gemini API key used by backend/ai/llm.py
GEMINI_API_KEY=your_gemini_api_key_here

# Optional explicit Gemini model override.
# Recommended stable values:
# - gemini-2.5-flash
# - gemini-2.5-pro
# - gemini-2.0-flash
GEMINI_MODEL=
